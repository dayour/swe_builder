# =============================================================================
# MCS Agent Builder - .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Screenshots & images (use /docs for intentional documentation)
# -----------------------------------------------------------------------------
*.png
*.jpg
*.jpeg
*.gif
*.wav

# -----------------------------------------------------------------------------
# Generated files
# -----------------------------------------------------------------------------
dashboard-data.js
.swe_builder.lock
*.tgz

# -----------------------------------------------------------------------------
# Personal config (use session-config.example.json as template)
# -----------------------------------------------------------------------------
tools/session-config.json
tools/om-cli/.source-hash

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
.venv/
venv/
ENV/
env/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
pip-log.txt
pip-delete-this-directory.txt

# -----------------------------------------------------------------------------
# Node.js
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# Environment & Secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
credentials.json
secrets.json

# -----------------------------------------------------------------------------
# Claude Code - User Specific
# -----------------------------------------------------------------------------
# Local settings contain user-specific permissions - each user configures their own
.claude/settings.local.json

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
*-stderr.txt
*-stdout.txt

# -----------------------------------------------------------------------------
# Build Outputs & Artifacts
# -----------------------------------------------------------------------------
output/
app/dist/
app/frontend/node_modules/

# -----------------------------------------------------------------------------
# Browser MCP - Session Data
# -----------------------------------------------------------------------------
.playwright-mcp/
playwright-report/
test-results/

# -----------------------------------------------------------------------------
# IDE & Editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Windows Artifacts
# -----------------------------------------------------------------------------
nul
*.tmp
desktop.ini

# -----------------------------------------------------------------------------
# Temporary Files
# -----------------------------------------------------------------------------
tmp/
temp/
*.bak
*.backup

# -----------------------------------------------------------------------------
# User Work (not part of shareable repo)
# -----------------------------------------------------------------------------
Build-Guides/
learnings/
!knowledge/learnings/
scripts/

# Note: docs/ is the GitHub Pages source and IS tracked.
# Local working notes should go in Build-Guides/ or scripts/ instead.
